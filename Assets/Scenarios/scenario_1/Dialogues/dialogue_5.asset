  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_5
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u0422\u0435\u043F\u0435\u0440\u044C, \u0445\u043E\u0447\u0443 \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u0438\u0442\u044C
      \u0442\u0435\u0431\u044F, \u0442\u044B \u0433\u043E\u0442\u043E\u0432?"
    en: "Now I want to satisfy you \u2014 are you ready?"
    de: "Jetzt will ich dich befriedigen \u2013 bist du bereit?"
    zh: "\u73B0\u5728\u6211\u60F3\u8BA9\u4F60\u723D\uFF0C\u4F60\u51C6\u5907\u597D\u4E86\u5417\uFF1F"
    fr: "Maintenant je veux te faire jouir, tu es pr\xEAt ?"
    hi: "\u0905\u092C \u092E\u0948\u0902 \u0924\u0941\u091D\u0947 \u0938\u0902\u0924\u0941\u0937\u094D\u091F
      \u0915\u0930\u0928\u093E \u091A\u093E\u0939\u0924\u0940 \u0939\u0942\u0901,
      \u0924\u0948\u092F\u093E\u0930 \u0939\u094B?"
    it: Ora voglio farti venire, sei pronto?
    ja: "\u4ECA\u5EA6\u306F\u541B\u3092\u30A4\u30AB\u305B\u305F\u3044\u3002\u6E96\u5099\u3067\u304D\u3066\u308B\uFF1F"
    pt: "Agora quero te satisfazer, est\xE1s pronto?"
    es: "Ahora quiero satisfacerte, \xBFest\xE1s listo?"
  phraseVariants:
  - answer:
      ru: "\u0421 \u044D\u0442\u043E\u0433\u043E \u0438 \u043D\u0430\u0434\u043E
        \u0431\u044B\u043B\u043E \u043D\u0430\u0447\u0438\u043D\u0430\u0442\u044C
        \u043D\u0430\u0448\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E!"
      en: "This is exactly how our acquaintance should\u2019ve started!"
      de: "Genau damit h\xE4tten wir anfangen sollen!"
      zh: "\u6211\u4EEC\u4E00\u5F00\u59CB\u5C31\u8BE5\u8FD9\u6837\u8BA4\u8BC6\u7684\uFF01"
      fr: "C\u2019est exactement comme \xE7a qu\u2019on aurait d\xFB commencer !"
      hi: "\u0939\u092E\u093E\u0930\u0940 \u091C\u093E\u0928-\u092A\u0939\u091A\u093E\u0928
        \u092F\u0939\u0940\u0902 \u0938\u0947 \u0936\u0941\u0930\u0942 \u0939\u094B\u0928\u0940
        \u091A\u093E\u0939\u093F\u090F \u0925\u0940!"
      it: "Era proprio cos\xEC che dovevamo iniziare!"
      ja: "\u6700\u521D\u304B\u3089\u3053\u3046\u3059\u308B\u3079\u304D\u3060\u3063\u305F\uFF01"
      pt: "Era exatamente assim que dev\xEDamos ter come\xE7ado!"
      es: "\xA1As\xED es exactamente como deber\xEDamos haber empezado!"
    respect: 4
  - answer:
      ru: "\u042F \u0443\u0436\u0435 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
        \u0432\u043E\u0437\u0431\u0443\u0436\u0434\u0435\u043D!"
      en: "I\u2019m already at peak arousal!"
      de: Ich bin schon total geil!
      zh: "\u6211\u5DF2\u7ECF\u786C\u5230\u4E0D\u884C\u4E86\uFF01"
      fr: "Je suis d\xE9j\xE0 au maximum de l\u2019excitation !"
      hi: "\u092E\u0948\u0902 \u0924\u094B \u092A\u0942\u0930\u0940 \u0924\u0930\u0939
        \u0938\u0947 \u0909\u0924\u094D\u0924\u0947\u091C\u093F\u0924 \u0939\u094B
        \u091A\u0941\u0915\u093E \u0939\u0942\u0901!"
      it: "Sono gi\xE0 al massimo dell\u2019eccitazione!"
      ja: "\u3082\u3046MAX\u306B\u8208\u596E\u3057\u3066\u308B\uFF01"
      pt: "J\xE1 estou no m\xE1ximo do tes\xE3o!"
      es: "\xA1Ya estoy al m\xE1ximo de excitaci\xF3n!"
    respect: 2
  - answer:
      ru: "\u041F\u044B\u0442\u0430\u044E\u0441\u044C \u0441\u0435\u0439\u0447\u0430\u0441
        \u0441\u043E\u0432\u043B\u0430\u0434\u0430\u0442\u044C \u0441 \u0441\u043E\u0431\u043E\u0439."
      en: "I\u2019m trying so hard to control myself right now."
      de: Ich versuche gerade, mich zu beherrschen.
      zh: "\u73B0\u5728\u6B63\u62FC\u547D\u5FCD\u7740\u5462\u3002"
      fr: "J\u2019essaie de me contr\xF4ler l\xE0 tout de suite."
      hi: "\u0905\u092D\u0940 \u0916\u0941\u0926 \u0915\u094B \u0915\u0902\u091F\u094D\u0930\u094B\u0932
        \u0915\u0930\u0928\u0947 \u0915\u0940 \u0915\u094B\u0936\u093F\u0936 \u0915\u0930
        \u0930\u0939\u093E \u0939\u0942\u0901\u0964"
      it: Sto cercando di controllarmi adesso.
      ja: "\u4ECA\u3081\u3063\u3061\u3083\u6211\u6162\u3057\u3066\u308B\u3002"
      pt: Estou tentando me controlar agora.
      es: Estoy intentando controlarme ahora mismo.
    respect: 0
  id: 0
