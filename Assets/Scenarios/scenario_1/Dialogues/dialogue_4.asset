  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_4
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u041A\u0430\u043A \u0442\u0435\u0431\u0435 \u043C\u043E\u044F \u043F\u043E\u043F\u043A\u0430?"
    en: How do you like my ass?
    de: Wie findest du meinen Arsch?
    zh: "\u89C9\u5F97\u6211\u7684\u5C41\u80A1\u600E\u4E48\u6837\uFF1F"
    fr: Tu aimes mon cul ?
    hi: "\u092E\u0947\u0930\u0940 \u0917\u093E\u0902\u0921 \u0915\u0948\u0938\u0940
      \u0932\u0917 \u0930\u0939\u0940 \u0939\u0948?"
    it: Ti piace il mio culo?
    ja: "\u79C1\u306E\u304A\u5C3B\u3001\u3069\u3046\uFF1F"
    pt: Gostas da minha bunda?
    es: "\xBFQu\xE9 tal mi culo?"
  phraseVariants:
  - answer:
      ru: "\u0423\u0436\u0435 \u0445\u043E\u0447\u0443 \u0432 \u043D\u0435\u0451
        \u0432\u043E\u0439\u0442\u0438!"
      en: I already want to slide inside!
      de: Ich will sofort in dich rein!
      zh: "\u5DF2\u7ECF\u60F3\u63D2\u8FDB\u53BB\u4E86\uFF01"
      fr: "Je veux d\xE9j\xE0 te p\xE9n\xE9trer !"
      hi: "\u0905\u092D\u0940 \u0938\u0947 \u0924\u0947\u0930\u0940 \u0917\u093E\u0902\u0921
        \u092E\u0947\u0902 \u0918\u0941\u0938\u0928\u093E \u091A\u093E\u0939\u0924\u093E
        \u0939\u0942\u0901!"
      it: "Voglio gi\xE0 entrarti dentro!"
      ja: "\u3082\u3046\u5165\u308C\u305F\u3044\uFF01"
      pt: "J\xE1 quero meter em ti!"
      es: "\xA1Ya quiero met\xE9rtela!"
    respect: 4
  - answer:
      ru: "\u042D\u0442\u0438 \u0444\u043E\u0440\u043C\u044B \u0432\u043E\u0437\u0431\u0443\u0436\u0434\u0430\u044E\u0442!"
      en: These curves drive me crazy!
      de: "Diese Kurven machen mich verr\xFCckt!"
      zh: "\u8FD9\u66F2\u7EBF\u592A\u523A\u6FC0\u4E86\uFF01"
      fr: Ces formes me rendent fou !
      hi: "\u092F\u0947 \u0936\u0947\u092A\u094D\u0938 \u0926\u0947\u0916\u0915\u0930
        \u092A\u093E\u0917\u0932 \u0939\u094B \u0930\u0939\u093E \u0939\u0942\u0901!"
      it: Queste curve mi fanno impazzire!
      ja: "\u305D\u306E\u30AB\u30FC\u30D6\u306B\u72C2\u3044\u305D\u3046\uFF01"
      pt: Essas curvas me deixam louco!
      es: "\xA1Estas curvas me vuelven loco!"
    respect: 2
  - answer:
      ru: "\u0413\u043E\u0442\u043E\u0432 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
        \u043D\u0430 \u043D\u0435\u0451 \u0432\u0435\u0447\u043D\u043E!"
      en: I could stare at it forever!
      de: "Ich k\xF6nnte ewig drauf starren!"
      zh: "\u53EF\u4EE5\u4E00\u76F4\u76EF\u7740\u770B\uFF01"
      fr: Je pourrais la regarder pour toujours !
      hi: "\u0907\u0938\u0947 \u0939\u092E\u0947\u0936\u093E \u0928\u093F\u0939\u093E\u0930
        \u0938\u0915\u0924\u093E \u0939\u0942\u0901!"
      it: La guarderei per sempre!
      ja: "\u305A\u3063\u3068\u898B\u3066\u3089\u308C\u308B\uFF01"
      pt: Poderia olhar para sempre!
      es: "\xA1Podr\xEDa mirarla eternamente!"
    respect: 0
  id: 0
