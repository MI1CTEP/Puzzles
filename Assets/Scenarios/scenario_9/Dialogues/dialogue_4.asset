      hi: "\u092F\u0939 \u090F\u0915 \u0926\u0941\u0930\u094D\u0918\u091F\u0928\u093E
        \u0925\u0940 \u0915\u094D\u092F\u094B\u0902\u0915\u093F \u0906\u092A\u0928\u0947
        \u0905\u092A\u0928\u0947 \u0936\u0949\u0930\u094D\u091F\u094D\u0938 \u0909\u0924\u093E\u0930
