  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_3
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u0422\u044B \u0432\u0435\u0434\u0435\u0448\u044C \u0441\u0435\u0431\u044F
      \u0445\u043E\u0440\u043E\u0448\u043E, \u0434\u0443\u043C\u0430\u044E \u0442\u0435\u0431\u0435
      \u0443\u0436\u0435 \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
      \u0433\u0440\u0443\u0434\u044C, \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F?"
    en: "You\u2019ve been good \u2014 I think you deserve to see my breasts now.
      Like them?"
    de: "Du bist brav gewesen \u2013 ich denke, du verdienst es, meine Br\xFCste
      zu sehen. Gefallen sie dir?"
    zh: "\u4F60\u8868\u73B0\u4E0D\u9519\uFF0C\u6211\u60F3\u53EF\u4EE5\u7ED9\u4F60\u770B\u6211\u7684\u80F8\u90E8\u4E86\uFF0C\u559C\u6B22\u5417\uFF1F"
    fr: "Tu as \xE9t\xE9 sage \u2014 je pense que tu m\xE9rites de voir mes seins.
      Ils te plaisent ?"
    hi: "\u0924\u0942 \u0905\u091A\u094D\u091B\u093E \u092C\u0930\u094D\u0924\u093E\u0935
      \u0915\u0930 \u0930\u0939\u093E \u0939\u0948, \u0932\u0917\u0924\u093E \u0939\u0948
      \u0924\u0947\u0930\u0947 \u0915\u094B \u092E\u0947\u0930\u0940 \u091A\u0942\u091A\u093F\u092F\u093E\u0901
      \u0926\u093F\u0916\u093E \u0926\u0942\u0901\u0964 \u092A\u0938\u0902\u0926
      \u0906\u0908\u0902?"
    it: "Ti sei comportato bene \u2014 penso che meriti di vedere il mio seno. Ti
      piace?"
    ja: "\u3044\u3044\u5B50\u306B\u3057\u3066\u305F\u306D\u3002\u3082\u3046\u304A\u3063\u3071\u3044\u898B\u305B\u3066\u3042\u3052\u308B\u3002\u6C17\u306B\u5165\u3063\u305F\uFF1F"
    pt: "Portaste-te bem \u2014 acho que mereces ver os meus peitos. Gostam?"
    es: "Te has portado bien \u2014 creo que mereces ver mis pechos. \xBFTe gustan?"
  phraseVariants:
  - answer:
      ru: "\u0414\u0430, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0442\u0435\u0431\u0435
        \u044F \u0438\u0434\u0443 \u043D\u0430 \u043F\u043E\u043F\u0440\u0430\u0432\u043A\u0443,
        \u0442\u044B \u0437\u0430\u0431\u043E\u0442\u043B\u0438\u0432\u0430\u044F."
      en: "Yes, thanks to you I\u2019m feeling much better \u2014 you\u2019re so
        caring."
      de: "Ja, dank dir geht\u2019s mir besser \u2013 du bist so f\xFCrsorglich."
      zh: "\u662F\u7684\uFF0C\u591A\u4E8F\u4F60\u6211\u597D\u591A\u4E86\uFF0C\u4F60\u771F\u4F53\u8D34\u3002"
      fr: "Oui, gr\xE2ce \xE0 toi je vais beaucoup mieux \u2014 tu es si attentionn\xE9e."
      hi: "\u0939\u093E\u0901, \u0924\u0947\u0930\u0940 \u0935\u091C\u0939 \u0938\u0947
        \u0920\u0940\u0915 \u0939\u094B \u0930\u0939\u093E \u0939\u0942\u0901 \u2014
        \u0924\u0942 \u0915\u093F\u0924\u0928\u0940 \u0915\u0947\u092F\u0930\u093F\u0902\u0917
        \u0939\u0948\u0964"
      it: "S\xEC, grazie a te sto guarendo \u2014 sei cos\xEC premurosa."
      ja: "\u3046\u3093\u3001\u541B\u306E\u304A\u304B\u3052\u3067\u56DE\u5FA9\u3057\u3066\u308B\u3088\u3002\u512A\u3057\u3044\u306D\u3002"
      pt: "Sim, gra\xE7as a ti estou a melhorar \u2014 \xE9s t\xE3o carinhosa."
      es: "S\xED, gracias a ti me estoy recuperando \u2014 eres tan cari\xF1osa."
    respect: 4
  - answer:
      ru: "\u041B\u044E\u0431\u043B\u044E \u0443\u043F\u0440\u0443\u0433\u0443\u044E
        \u0433\u0440\u0443\u0434\u044C!"
      en: I love firm breasts!
      de: "Ich liebe straffe Br\xFCste!"
      zh: "\u6211\u559C\u6B22\u7D27\u5B9E\u7684\u80F8\u90E8\uFF01"
      fr: "J\u2019adore les seins fermes !"
      hi: "\u092E\u0941\u091D\u0947 \u091F\u093E\u0907\u091F \u091A\u0942\u091A\u093F\u092F\u093E\u0901
        \u092C\u0939\u0941\u0924 \u092A\u0938\u0902\u0926 \u0939\u0948\u0902!"
      it: Amo il seno sodo!
      ja: "\u5F35\u308A\u306E\u3042\u308B\u304A\u3063\u3071\u3044\u304C\u597D\u304D\uFF01"
      pt: Adoro peitos firmes!
      es: "\xA1Amo los pechos firmes!"
    respect: 2
  - answer:
      ru: "\u0425\u043E\u0447\u0443 \u043F\u043E\u0442\u0440\u043E\u0433\u0430\u0442\u044C
        \u0435\u0451!"
      en: I want to touch them!
      de: Ich will sie anfassen!
      zh: "\u60F3\u6478\u6478\u5B83\u4EEC\uFF01"
      fr: Je veux les toucher !
      hi: "\u0907\u0928\u094D\u0939\u0947\u0902 \u091B\u0942\u0928\u093E \u091A\u093E\u0939\u0924\u093E
        \u0939\u0942\u0901!"
      it: Voglio toccarle!
      ja: "\u89E6\u308A\u305F\u3044\uFF01"
      pt: "Quero toc\xE1-las!"
      es: "\xA1Quiero tocarlas!"
    respect: 0
  id: 0
