      ja: "\u3046\u3093\u3001\u305D\u308C\u304C\u4FFA\u306E\u30D5\u30A7\u30C1\u3002\u6065\u305A\u304B\u3057\u304C\u308A\u5C4B\u306A\u306E\u306B\u30A8\u30ED\u3044\u3063\u3066\u6700\u9AD8\u3002"
