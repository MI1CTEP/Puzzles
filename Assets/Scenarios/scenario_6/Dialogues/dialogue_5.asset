  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_5
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u042D\u0442\u043E \u043C\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439
      \u0430\u043D\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u0435\u043A\u0441,
      \u043A\u0430\u043A\u0438\u0435 \u0443 \u0442\u0435\u0431\u044F \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u044F?"
    en: "This is my first anal \u2014 how does it feel for you?"
    de: "Das ist mein erstes Mal Anal \u2013 wie f\xFChlt es sich f\xFCr dich an?"
    zh: "\u8FD9\u662F\u6211\u548C\u4F60\u7684\u7B2C\u4E00\u6B21\u809B\u4EA4\uFF0C\u611F\u89C9\u5982\u4F55\uFF1F"
    fr: "C\u2019est ma premi\xE8re fois en anal \u2013 comment c\u2019est pour toi
      ?"
    hi: "\u0924\u0947\u0930\u0947 \u0938\u093E\u0925 \u092E\u0947\u0930\u093E \u092A\u0939\u0932\u093E
      \u0905\u0928\u0932 \u0939\u0948 \u2013 \u0924\u0941\u091D\u0947 \u0915\u0948\u0938\u093E
      \u0932\u0917 \u0930\u0939\u093E \u0939\u0948?"
    it: "\xC8 la mia prima volta anale con te \u2013 come ti senti?"
    ja: "\u541B\u3068\u304C\u521D\u3081\u3066\u306E\u30A2\u30CA\u30EB\u3002\u3069\u3046\uFF1F\u6C17\u6301\u3061\u3044\u3044\uFF1F"
    pt: "\xC9 a minha primeira vez anal contigo \u2013 como te sentes?"
    es: "Es mi primera vez anal contigo \u2013 \xBFc\xF3mo se siente?"
  phraseVariants:
  - answer:
      ru: "\u0423 \u0442\u0435\u0431\u044F \u0443\u043F\u0440\u0443\u0433\u0430\u044F
        \u043F\u043E\u043F\u043A\u0430 \u044E\u043D\u043E\u0439 \u0434\u0435\u0432\u0443\u0448\u043A\u0438,
        \u043B\u0443\u0447\u0448\u0435\u0435 \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u0435
        \u0441\u0435\u043A\u0441\u0430."
      en: "You have the firm ass of a young girl \u2014 the perfect way to end sex."
      de: "Du hast den straffen Arsch einer jungen Frau \u2013 der perfekte Abschluss."
      zh: "\u4F60\u6709\u5E74\u8F7B\u5973\u5B69\u7D27\u5B9E\u7684\u5C41\u80A1\uFF0C\u6700\u5B8C\u7F8E\u7684\u7ED3\u675F\u3002"
      fr: "Tu as le cul ferme d\u2019une jeune fille \u2013 la fin parfaite."
      hi: "\u0924\u0947\u0930\u0940 \u0917\u093E\u0902\u0921 \u090F\u0915 \u091C\u0935\u093E\u0928
        \u0932\u0921\u093C\u0915\u0940 \u091C\u0948\u0938\u0940 \u091F\u093E\u0907\u091F
        \u0939\u0948 \u2013 \u0938\u0947\u0915\u094D\u0938 \u0915\u093E \u092A\u0930\u092B\u0947\u0915\u094D\u091F
        \u090F\u0902\u0921\u093F\u0902\u0917\u0964"
      it: "Hai il culo sodo di una ragazza giovane \u2013 la conclusione perfetta."
      ja: "\u82E5\u3044\u5B50\u306E\u30D7\u30EA\u30D7\u30EA\u304A\u5C3B\u3060\u306D\u3002\u6700\u9AD8\u306E\u7DE0\u3081\u304F\u304F\u308A\u3002"
      pt: "Tens a bunda rija de uma mi\xFAda jovem \u2013 o final perfeito."
      es: "Tienes el culo firme de una chica joven \u2013 el final perfecto."
    respect: 4
  - answer:
      ru: "\u041C\u043D\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F, \u043A\u043E\u0433\u0434\u0430
        \u0447\u043B\u0435\u043D \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
        \u0432 \u0442\u0435\u0431\u0435."
      en: I love when my cock is completely inside you.
      de: "Mir gef\xE4llt\u2019s, wenn mein Schwanz ganz tief in dir steckt."
      zh: "\u6211\u559C\u6B22\u9E21\u9E21\u5B8C\u5168\u63D2\u8FDB\u4F60\u91CC\u9762\u3002"
      fr: "J\u2019aime quand ma queue est compl\xE8tement enfouie en toi."
      hi: "\u092E\u0941\u091D\u0947 \u092C\u0939\u0941\u0924 \u092E\u091C\u093C\u093E
        \u0906\u0924\u093E \u0939\u0948 \u091C\u092C \u092E\u0947\u0930\u093E \u0932\u0902\u0921
        \u0924\u0947\u0930\u0947 \u0905\u0902\u0926\u0930 \u092A\u0942\u0930\u093E
        \u0918\u0941\u0938\u093E \u0939\u094B\u0964"
      it: "Mi piace quando il mio cazzo \xE8 tutto dentro di te."
      ja: "\u30C1\u30F3\u30DD\u304C\u5965\u307E\u3067\u5165\u3063\u3066\u308B\u306E\u597D\u304D\u3002"
      pt: "Gosto quando o meu pau est\xE1 completamente dentro de ti."
      es: "Me encanta cuando mi polla est\xE1 totalmente dentro de ti."
    respect: 2
  - answer:
      ru: "\u042F \u043F\u043E\u043B\u0443\u0447\u0430\u044E \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435,
        \u043D\u043E \u043C\u043E\u0436\u0435\u0442 \u0441\u043C\u0435\u043D\u0438\u043C
        \u043F\u043E\u0437\u0443?"
      en: "I\u2019m enjoying it, but maybe change position?"
      de: "Ich genie\xDFe es \u2013 aber vielleicht wechseln wir mal die Stellung?"
      zh: "\u6211\u5F88\u4EAB\u53D7\uFF0C\u4E0D\u8FC7\u53EF\u4EE5\u6362\u4E2A\u59FF\u52BF\u5417\uFF1F"
      fr: "J\u2019aime beaucoup \u2013 mais on change de position ?"
      hi: "\u092E\u091C\u093C\u093E \u0924\u094B \u0906 \u0930\u0939\u093E \u0939\u0948
        \u2013 \u092A\u0930 \u092A\u094B\u095B\u093F\u0936\u0928 \u091A\u0947\u0902\u091C
        \u0915\u0930 \u0932\u0947\u0902?"
      it: "Mi piace \u2013 ma magari cambiamo posizione?"
      ja: "\u6C17\u6301\u3061\u3044\u3044\u3051\u3069\u3001\u30DD\u30B8\u30B7\u30E7\u30F3\u5909\u3048\u3066\u307F\u308B\uFF1F"
      pt: "Estou a curtir \u2013 mas podemos mudar de posi\xE7\xE3o?"
      es: "Me gusta mucho \u2013 pero \xBFcambiamos de postura?"
    respect: 0
  id: 0
