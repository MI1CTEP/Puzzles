  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_5
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u0421\u0435\u0439\u0447\u0430\u0441 \u044F \u043F\u043E\u043A\u0430\u0436\u0443
      \u0442\u0435\u0431\u0435, \u043A\u0430\u043A \u044F \u043F\u0440\u043E\u0432\u043E\u0436\u0443
      \u043E\u0434\u0438\u043D\u043E\u043A\u0438\u0435 \u0432\u0435\u0447\u0435\u0440\u0430
      \u043D\u0430 \u043F\u043B\u044F\u0436\u0435, \u0432\u043E\u0437\u0431\u0443\u0436\u0434\u0430\u0435\u0442?"
    en: "I\u2019ll show you how I spend lonely evenings on the beach \u2014 does
      it turn you on?"
    de: "Jetzt zeig ich dir, wie ich einsame Abende am Strand verbringe \u2013 macht
      dich das an?"
    zh: "\u73B0\u5728\u7ED9\u4F60\u770B\u770B\u6211\u5728\u6D77\u6EE9\u4E0A\u600E\u4E48\u5EA6\u8FC7\u5B64\u5355\u7684\u591C\u665A\uFF0C\u5174\u594B\u5417\uFF1F"
    fr: "Je vais te montrer comment je passe mes soir\xE9es solitaires sur la plage
      \u2014 \xE7a t\u2019excite ?"
    hi: "\u0905\u092C \u0926\u0947\u0916 \u092E\u0948\u0902 \u0905\u0915\u0947\u0932\u0947
      \u092C\u0940\u091A \u092A\u0930 \u0936\u093E\u092E\u0947\u0902 \u0915\u0948\u0938\u0947
      \u092C\u093F\u0924\u093E\u0924\u0940 \u0939\u0942\u0901 \u2014 \u0909\u0924\u094D\u0924\u0947\u091C\u093F\u0924
      \u0939\u094B \u0930\u0939\u093E \u0939\u0948?"
    it: "Ora ti mostro come passo le serate solitarie in spiaggia \u2014 ti eccita?"
    ja: "\u4ECA\u304B\u3089\u5BC2\u3057\u3044\u30D3\u30FC\u30C1\u306E\u591C\u306E\u904E\u3054\u3057\u65B9\u898B\u305B\u3066\u3042\u3052\u308B\u3002\u8208\u596E\u3059\u308B\uFF1F"
    pt: "Vou mostrar-te como passo as noites sozinha na praia \u2014 excita-te?"
    es: "Te muestro c\xF3mo paso mis noches solitarias en la playa \u2014 \xBFte
      excita?"
  phraseVariants:
  - answer:
      ru: "\u041D\u0430 \u0437\u0430\u043A\u0430\u0442\u0435 \u044D\u0442\u043E \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
        \u0432\u043E\u043B\u0448\u0435\u0431\u043D\u043E, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439!"
      en: "At sunset it looks magical \u2014 keep going!"
      de: "Bei Sonnenuntergang sieht das magisch aus \u2013 mach weiter!"
      zh: "\u5915\u9633\u4E0B\u770B\u8D77\u6765\u8D85\u6D6A\u6F2B\uFF0C\u7EE7\u7EED\uFF01"
      fr: "Au coucher du soleil c\u2019est magique \u2014 continue !"
      hi: "\u0938\u0942\u0930\u091C \u0921\u0942\u092C\u0924\u0947 \u0935\u0915\u094D\u0924
        \u092F\u0947 \u091C\u093E\u0926\u0941\u0908 \u0932\u0917\u0924\u093E \u0939\u0948
        \u2014 \u091C\u093E\u0930\u0940 \u0930\u0916!"
      it: "Al tramonto sembra magico \u2014 continua!"
      ja: "\u5915\u967D\u306E\u4E0B\u3060\u3068\u9B54\u6CD5\u307F\u305F\u3044\u3002\u7D9A\u3051\u3066\uFF01"
      pt: "Com o p\xF4r do sol parece m\xE1gico \u2014 continua!"
      es: "Con la puesta de sol parece m\xE1gico \u2014 \xA1sigue!"
    respect: 4
  - answer:
      ru: "\u0425\u043E\u0442\u0435\u043B \u0431\u044B \u0435\u0449\u0435 \u0440\u0430\u0437
        \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F \u0441\u0435\u043A\u0441\u043E\u043C."
      en: "I\u2019d love to fuck again."
      de: "Ich w\xFCrde gern nochmal ficken."
      zh: "\u6211\u60F3\u518D\u6765\u4E00\u6B21\u3002"
      fr: "J\u2019aimerais baiser encore une fois."
      hi: "\u092E\u0941\u091D\u0947 \u090F\u0915 \u092C\u093E\u0930 \u0914\u0930
        \u091A\u094B\u0926\u0928\u093E \u0939\u0948\u0964"
      it: Vorrei scopare ancora.
      ja: "\u3082\u3046\u4E00\u56DE\u30BB\u30C3\u30AF\u30B9\u3057\u305F\u3044\u3002"
      pt: Gostaria de foder outra vez.
      es: "Me encantar\xEDa follar otra vez."
    respect: 2
  - answer:
      ru: "\u041D\u0435\u043F\u043B\u043E\u0445\u043E, \u0432\u0438\u0434\u0438\u043C\u043E
        \u0442\u0435\u0431\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F
        \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E."
      en: "Not bad \u2014 looks like you enjoy being alone."
      de: "Nicht schlecht \u2013 offenbar magst du Einsamkeit."
      zh: "\u8FD8\u4E0D\u9519\uFF0C\u770B\u6765\u4F60\u633A\u4EAB\u53D7\u5B64\u72EC\u7684\u3002"
      fr: "Pas mal \u2014 on dirait que tu aimes la solitude."
      hi: "\u092C\u0941\u0930\u093E \u0928\u0939\u0940\u0902 \u2014 \u0932\u0917\u0924\u093E
        \u0939\u0948 \u0924\u0941\u091D\u0947 \u0905\u0915\u0947\u0932\u093E\u092A\u0928
        \u092A\u0938\u0902\u0926 \u0939\u0948\u0964"
      it: "Niente male \u2014 sembra che ti piaccia la solitudine."
      ja: "\u60AA\u304F\u306A\u3044\u306D\u3002\u5B64\u72EC\u3082\u597D\u304D\u306A\u3093\u3060\u3002"
      pt: "Nada mau \u2014 parece que gostas da solid\xE3o."
      es: "No est\xE1 mal \u2014 parece que te gusta la soledad."
    respect: 0
  id: 0
