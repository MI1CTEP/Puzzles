  m_Script: {fileID: 11500000, guid: 1e6982f52e7d42440a758671d1357932, type: 3}
  m_Name: dialogue_4
  m_EditorClassIdentifier: 
  firstPhrase:
    ru: "\u042F \u043F\u043E\u043C\u043E\u0433\u0443 \u0442\u0435\u0431\u0435 \u0441\u043D\u044F\u0442\u044C
      \u0441\u0442\u0440\u0435\u0441\u0441, \u0433\u043E\u0442\u043E\u0432 \u0432\u043E\u0439\u0442\u0438
      \u0432 \u043C\u0435\u043D\u044F?"
    en: "I\u2019ll help you relieve stress \u2014 ready to slide inside me?"
    de: "Ich helfe dir, Stress abzubauen \u2013 bereit, in mich reinzugleiten?"
    zh: "\u6211\u5E2E\u4F60\u51CF\u538B\uFF0C\u51C6\u5907\u597D\u63D2\u8FDB\u6765\u4E86\u5417\uFF1F"
    fr: "Je vais t\u2019aider \xE0 \xE9vacuer le stress \u2014 pr\xEAt \xE0 glisser
      en moi ?"
    hi: "\u092E\u0948\u0902 \u0924\u0947\u0930\u093E \u0938\u094D\u091F\u094D\u0930\u0947\u0938
      \u0926\u0942\u0930 \u0915\u0930 \u0926\u0942\u0901\u0917\u0940 \u2014 \u092E\u0947\u0930\u0947
      \u0905\u0902\u0926\u0930 \u0906\u0928\u0947 \u0915\u094B \u0924\u0948\u092F\u093E\u0930?"
    it: "Ti aiuto a scaricare lo stress \u2014 pronto a scivolare dentro di me?"
    ja: "\u30B9\u30C8\u30EC\u30B9\u89E3\u6D88\u3057\u3066\u3042\u3052\u308B\u3002\u5165\u3063\u3066\u304F\u308B\u6E96\u5099\u3067\u304D\u305F\uFF1F"
    pt: "Vou ajudar-te a aliviar o stress \u2014 pronto para entrar em mim?"
    es: "Te ayudo a quitar el estr\xE9s \u2014 \xBFlisto para deslizarte dentro?"
  phraseVariants:
  - answer:
      ru: "\u041C\u043E\u044F \u043C\u0435\u0447\u0442\u0430, \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
        \u0441\u0435\u043A\u0441\u043E\u043C \u0441 \u0442\u043E\u0431\u043E\u0439
        \u043A\u0430\u0436\u0434\u044B\u0439 \u0434\u0435\u043D\u044C."
      en: My dream is to fuck you every single day.
      de: Mein Traum ist, jeden Tag mit dir zu ficken.
      zh: "\u6211\u7684\u68A6\u60F3\u5C31\u662F\u6BCF\u5929\u8DDF\u4F60\u505A\u7231\u3002"
      fr: "Mon r\xEAve c\u2019est de baiser avec toi tous les jours."
      hi: "\u092E\u0947\u0930\u093E \u0938\u092A\u0928\u093E \u0939\u0948 \u0930\u094B\u091C\u093C
        \u0924\u0941\u091D\u0947 \u091A\u094B\u0926\u0928\u093E\u0964"
      it: "Il mio sogno \xE8 scopare con te ogni singolo giorno."
      ja: "\u6BCE\u65E5\u541B\u3068\u30BB\u30C3\u30AF\u30B9\u3059\u308B\u306E\u304C\u5922\u3060\u3088\u3002"
      pt: "O meu sonho \xE9 foder contigo todos os dias."
      es: "Mi sue\xF1o es follar contigo todos los d\xEDas."
    respect: 4
  - answer:
      ru: "\u0414\u0430, \u044F \u0434\u0443\u043C\u0430\u044E \u0442\u0435\u0431\u0435
        \u043F\u043E\u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F."
      en: "Yes, I think you\u2019ll love it."
      de: Ja, ich glaube, das wird dir gefallen.
      zh: "\u662F\u7684\uFF0C\u6211\u89C9\u5F97\u4F60\u4F1A\u559C\u6B22\u7684\u3002"
      fr: Oui, je pense que tu vas adorer.
      hi: "\u0939\u093E\u0901, \u092E\u0941\u091D\u0947 \u092F\u0915\u0940\u0928
        \u0939\u0948 \u0924\u0941\u091D\u0947 \u092C\u0939\u0941\u0924 \u092E\u091C\u093C\u093E
        \u0906\u090F\u0917\u093E\u0964"
      it: "S\xEC, credo che ti piacer\xE0 da morire."
      ja: "\u3046\u3093\u3001\u7D76\u5BFE\u6C17\u6301\u3061\u3044\u3044\u3088\u3002"
      pt: Sim, acho que vais adorar.
      es: "S\xED, creo que te va a encantar."
    respect: 2
  - answer:
      ru: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E, \u0442\u044B \u0431\u0443\u0434\u0435\u0448\u044C
        \u043A\u0440\u0438\u0447\u0430\u0442\u044C \u043E\u0442 \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F!"
      en: "Of course \u2014 you\u2019ll scream with pleasure!"
      de: "Klar \u2013 du wirst vor Lust schreien!"
      zh: "\u5F53\u7136\uFF0C\u4F60\u4F1A\u723D\u5230\u5C16\u53EB\uFF01"
      fr: "Bien s\xFBr \u2014 tu vas crier de plaisir !"
      hi: "\u091C\u093C\u0930\u0942\u0930 \u2014 \u0924\u0942 \u092A\u094D\u0932\u0947\u091C\u0930
        \u0938\u0947 \u091A\u0940\u0916\u0928\u0947 \u0932\u0917\u0947\u0917\u093E!"
      it: "Certo \u2014 urlerai dal piacere!"
      ja: "\u3082\u3061\u308D\u3093\uFF01\u6C17\u6301\u3061\u3088\u3059\u304E\u3066\u53EB\u3093\u3058\u3083\u3046\u3088\uFF01"
      pt: "Claro \u2014 vais gritar de prazer!"
      es: "\xA1Claro \u2014 vas a gritar de placer!"
    respect: 0
  id: 0
