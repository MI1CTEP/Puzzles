  nameLevel: Skylar
  languages:
    ru: "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 Skylar, \u044F \u0441\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
      \u043D\u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u043C
      \u043F\u043B\u044F\u0436\u0435, \u0438 \u0438\u043C\u0435\u043D\u043D\u043E
      \u044F \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0430, \u043A\u0430\u043A
      \xAB$$$\xBB \u043D\u0430\u0447\u0430\u043B \u0442\u043E\u043D\u0443\u0442\u044C
      \u0437\u0430 \u0431\u0443\u0439\u043A\u0430\u043C\u0438. \u042F \u0431\u0440\u043E\u0441\u0438\u043B\u0430\u0441\u044C
      \u0432 \u0432\u043E\u0434\u0443 \u0432 \u0441\u0432\u043E\u0451\u043C \u043E\u0431\u0442\u044F\u0433\u0438\u0432\u0430\u044E\u0449\u0435\u043C
      \u043A\u0440\u0430\u0441\u043D\u043E\u043C \u043A\u0443\u043F\u0430\u043B\u044C\u043D\u0438\u043A\u0435,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0435\u043B\u0435 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
      \u043C\u043E\u044E \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u0442\u044F\u0436\u0451\u043B\u0443\u044E
      \u0433\u0440\u0443\u0434\u044C \u0438 \u0441\u043E\u0447\u043D\u0443\u044E
      \u043A\u0440\u0443\u0433\u043B\u0443\u044E \u043F\u043E\u043F\u043A\u0443,
      \u0438 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u0441\u0435\u043A\u0443\u043D\u0434 \u0443\u0436\u0435 \u0442\u0430\u0449\u0438\u043B\u0430
      \u0435\u0433\u043E \u043D\u0430 \u0431\u0435\u0440\u0435\u0433. \u041A\u043E\u0433\u0434\u0430
      \u044F \u0434\u0435\u043B\u0430\u044E \u043C\u0430\u0441\u0441\u0430\u0436
      \u0441\u0435\u0440\u0434\u0446\u0430 \u0438\u043B\u0438 \u0434\u044B\u0445\u0430\u043D\u0438\u0435
      \u0440\u043E\u0442 \u0432 \u0440\u043E\u0442, \u043C\u043E\u0438 \u0444\u043E\u0440\u043C\u044B
      \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u043D\u0430\u043A\u0440\u044B\u0432\u0430\u044E\u0442
      \u043F\u0430\u0446\u0438\u0435\u043D\u0442\u0430, \u0438 \u043C\u0443\u0436\u0447\u0438\u043D\u044B
      \u043E\u0436\u0438\u0432\u0430\u044E\u0442 \u043F\u0440\u044F\u043C\u043E \u043F\u043E\u0434\u043E
      \u043C\u043D\u043E\u0439. \u041D\u043E \u043B\u0443\u0447\u0448\u0435\u0435
      \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0442\u043E\u043C:
      \u044F \u043E\u0431\u043E\u0436\u0430\u044E \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F
      \u043D\u0430 \u043F\u043B\u044F\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
      \u0441\u043C\u0435\u043D\u044B, \u043A\u043E\u0433\u0434\u0430 \u043D\u0430\u0440\u043E\u0434\u0443
      \u043F\u043E\u0447\u0442\u0438 \u043D\u0435\u0442, \u0441\u043D\u044F\u0442\u044C
      \u044D\u0442\u043E\u0442 \u043C\u043E\u043A\u0440\u044B\u0439 \u043A\u0440\u0430\u0441\u043D\u044B\u0439
      \u043A\u0443\u043F\u0430\u043B\u044C\u043D\u0438\u043A \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E,
      \u043B\u0435\u0447\u044C \u0433\u043E\u043B\u0430\u044F \u043D\u0430 \u0442\u0451\u043F\u043B\u044B\u0439
      \u043F\u0435\u0441\u043E\u043A \u0438 \u043C\u0430\u0441\u0442\u0443\u0440\u0431\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0447\u0430\u0441\u0430\u043C\u0438. \u041F\u0430\u043B\u044C\u0447\u0438\u043A\u0438
      \u0441\u043A\u043E\u043B\u044C\u0437\u044F\u0442 \u043F\u043E \u043A\u043B\u0438\u0442\u043E\u0440\u0443,
      \u043F\u043E\u0442\u043E\u043C \u044F \u0434\u043E\u0441\u0442\u0430\u044E
      \u0438\u0437 \u0441\u0443\u043C\u043A\u0438 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
      \u0442\u043E\u043B\u0441\u0442\u044B\u0439 \u0434\u0438\u043B\u0434\u043E,
      \u0432\u0442\u044B\u043A\u0430\u044E \u0435\u0433\u043E \u043F\u0440\u044F\u043C\u043E
      \u0432 \u043F\u0435\u0441\u043E\u043A, \u0441\u0430\u0436\u0443\u0441\u044C
      \u0441\u0432\u0435\u0440\u0445\u0443 \u0438 \u043D\u0430\u0447\u0438\u043D\u0430\u044E
      \u043F\u0440\u044B\u0433\u0430\u0442\u044C \u2014 \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E,
      \u043F\u043E\u0442\u043E\u043C \u0432\u0441\u0451 \u0431\u044B\u0441\u0442\u0440\u0435\u0435,
      \u043F\u043E\u043A\u0430 \u043E\u0440\u0433\u0430\u0437\u043C \u043D\u0435
      \u043D\u0430\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u043C\u0435\u043D\u044F
      \u0442\u0430\u043A, \u0447\u0442\u043E \u044F \u043A\u0440\u0438\u0447\u0443
      \u043D\u0430\u0434 \u043F\u0443\u0441\u0442\u044B\u043C \u043F\u043B\u044F\u0436\u0435\u043C.
      \u0421\u0435\u043A\u0441 \u043D\u0430 \u043F\u043B\u044F\u0436\u0435 \u2014
      \u044D\u0442\u043E \u043C\u043E\u044F \u0441\u0442\u0440\u0430\u0441\u0442\u044C:
      \u0433\u043E\u043B\u044B\u0435 \u0442\u0435\u043B\u0430 \u043D\u0430 \u043F\u0435\u0441\u043A\u0435,
      \u0441\u043E\u043B\u0451\u043D\u044B\u0439 \u0432\u0435\u0442\u0435\u0440,
      \u0448\u0443\u043C \u0432\u043E\u043B\u043D, \u043A\u043E\u0433\u0434\u0430
      \u043C\u0435\u043D\u044F \u0431\u0435\u0440\u0443\u0442 \u0436\u0451\u0441\u0442\u043A\u043E
      \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E, \u0430 \u044F \u043F\u043E\u0442\u043E\u043C
      \u0441\u043D\u043E\u0432\u0430 \u0441\u043D\u0438\u043C\u0430\u044E \u0432\u0441\u0451
      \u0441 \u0441\u0435\u0431\u044F \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E
      \u0441 \u0434\u0438\u043B\u0434\u043E, \u043F\u043E\u043A\u0430 \u043D\u0435
      \u043A\u043E\u043D\u0447\u0443 \u0435\u0449\u0451 \u0440\u0430\u0437. \u041F\u043E\u0441\u043B\u0435
      \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u044F \u0432\u044B\u0442\u0430\u0449\u0438\u043B\u0430
      \u0435\u0433\u043E \u043D\u0430 \u0431\u0435\u0440\u0435\u0433, \u044F \u043E\u0442\u043D\u0435\u0441\u043B\u0430
      \u0435\u0433\u043E \u0432 \u0443\u043A\u0440\u043E\u043C\u043D\u043E\u0435
      \u043C\u0435\u0441\u0442\u043E \xAB\u043D\u0430 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435\xBB,
      \u0441\u043D\u044F\u043B\u0430 \u0441 \u0441\u0435\u0431\u044F \u043A\u0440\u0430\u0441\u043D\u044B\u0439
      \u043A\u0443\u043F\u0430\u043B\u044C\u043D\u0438\u043A, \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430
      \u0435\u043C\u0443 \u0432\u0441\u0451 \u2014 \u0438 \u0433\u0440\u0443\u0434\u044C,
      \u0438 \u043F\u043E\u043F\u043A\u0443, \u0438 \u043A\u0430\u043A \u044F \u043D\u0430\u0441\u0430\u0436\u0438\u0432\u0430\u044E\u0441\u044C
      \u043D\u0430 \u0441\u0432\u043E\u0439 \u0434\u0438\u043B\u0434\u043E \u043F\u0440\u044F\u043C\u043E
      \u043D\u0430 \u043F\u0435\u0441\u043A\u0435. \u041E\u043D \u043F\u0440\u0438\u0448\u0451\u043B
      \u0432 \u0441\u0435\u0431\u044F \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
      \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u043A\u0430\u0436\u0434\u044B\u0435
      \u0432\u044B\u0445\u043E\u0434\u043D\u044B\u0435 \xAB\u0442\u043E\u043D\u0435\u0442\xBB
      \u0432 \u043C\u043E\u0451\u043C \u0441\u0435\u043A\u0442\u043E\u0440\u0435,
      \u0447\u0442\u043E\u0431\u044B \u044F \u0441\u043D\u043E\u0432\u0430 \u0441\u043F\u0430\u0441\u0430\u043B\u0430
      \u0435\u0433\u043E, \u0430 \u043F\u043E\u0442\u043E\u043C \u043C\u044B \u043E\u0431\u0430
      \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C \u0433\u043E\u043B\u044B\u043C\u0438
      \u043D\u0430 \u043F\u0435\u0441\u043A\u0435 \u0434\u043E \u0443\u0442\u0440\u0430."
    en: "My name is Skylar, I\u2019m a lifeguard on the city\u2019s main beach, and
      I was the one who spotted \xAB$$$\xBB starting to drown beyond the buoys. I
      dove into the water in my tight red swimsuit that barely holds my huge heavy
      breasts and juicy round ass, and seconds later I was dragging him to shore. 
      When I do CPR or mouth-to-mouth, my curves literally cover the patient, and
      men come back to life right under me. But the best part comes after: I love
      staying on the beach after my shift when almost no one is around, peeling off
      that wet red swimsuit completely, lying naked on the warm sand and masturbating
      for hours. My fingers slide over my clit, then I pull out my big thick dildo
      from my bag, plant it right in the sand, straddle it and start bouncing \u2014
      slow at first, then faster and faster until the orgasm hits me so hard I scream
      across the empty beach.  Sex on the beach is my passion: naked bodies on the
      sand, salty breeze, the sound of waves while I\u2019m taken hard and deep,
      and then I strip again and keep riding my dildo until I cum once more. After
      I dragged him ashore, I carried him to a secluded spot \u201Cfor recovery\u201D,
      took off my red swimsuit, showed him everything \u2014 my tits, my ass, and
      how I impale myself on my dildo right in the sand. He snapped back to life
      instantly and now every weekend he \u201Cdrowns\u201D in my sector so I can
      rescue him again, and then we both stay naked on the sand until morning."
    de: "Ich hei\xDFe Skylar, ich bin Rettungsschwimmerin am Hauptstrand der Stadt
      und habe \xAB$$$\xBB jenseits der Bojen untergehen sehen. Ich sprang in meinem
      engen roten Badeanzug ins Wasser \u2013 der kaum meine riesigen schweren Br\xFCste
      und meinen saftigen runden Arsch h\xE4lt \u2013 und zog ihn Sekunden sp\xE4ter
      ans Ufer.  Wenn ich Herzmassage oder Mund-zu-Mund-Beatmung mache, bedecken
      meine Kurven den Patienten f\xF6rmlich, und M\xE4nner kommen direkt unter mir
      wieder zu sich. Aber das Beste kommt danach: Ich bleibe nach der Schicht am
      Strand, wenn fast niemand mehr da ist, ziehe den nassen roten Badeanzug komplett
      aus, lege mich nackt in den warmen Sand und masturbiere stundenlang. Finger
      gleiten \xFCber die Klit, dann hole ich meinen gro\xDFen dicken Dildo aus der
      Tasche, ramme ihn in den Sand, setze mich drauf und reite \u2013 erst langsam,
      dann immer schneller, bis der Orgasmus mich so \xFCberrollt, dass ich \xFCber
      den leeren Strand schreie.  Sex am Strand ist meine Leidenschaft: nackte K\xF6rper
      im Sand, salziger Wind, Wellenrauschen, w\xE4hrend ich hart und tief genommen
      werde \u2013 und danach ziehe ich wieder alles aus und reite weiter auf meinem
      Dildo, bis ich nochmal komme. Nachdem ich ihn an Land gezogen hatte, trug ich
      ihn an eine versteckte Stelle \u201Ezur Erholung\u201C, zog meinen roten Badeanzug
      aus, zeigte ihm alles \u2013 Titten, Arsch und wie ich mich auf meinem Dildo
      im Sand aufspie\xDFe. Er war sofort wieder bei Bewusstsein und jetzt \u201Eertrinkt\u201C
      er jedes Wochenende in meinem Abschnitt, damit ich ihn wieder rette \u2013
      und danach bleiben wir beide nackt im Sand bis zum Morgen."
    zh: "\u6211\u53EBSkylar\uFF0C\u662F\u5E02\u4E2D\u5FC3\u6D77\u6EE9\u7684\u6551\u751F\u5458\uFF0C\u90A3\u5929\u6211\u53D1\u73B0
      \xAB$$$\xBB \u5728\u6D6E\u6807\u5916\u5F00\u59CB\u6EBA\u6C34\u3002\u6211\u7A7F\u7740\u7D27\u7EF7\u7684\u7EA2\u8272\u6CF3\u8863\u51B2\u8FDB\u6C34\u91CC\u2014\u2014\u8FD9\u4EF6\u6CF3\u8863\u51E0\u4E4E\u5305\u4E0D\u4F4F\u6211\u7855\u5927\u6C89\u7538\u7538\u7684\u5976\u5B50\u548C\u80A5\u7F8E\u5706\u6DA6\u7684\u5C41\u80A1\u2014\u2014\u51E0\u79D2\u949F\u540E\u5C31\u628A\u4ED6\u62D6\u4E0A\u5CB8\u3002 
      \u505A\u5FC3\u80BA\u590D\u82CF\u6216\u8005\u4EBA\u5DE5\u547C\u5438\u65F6\uFF0C\u6211\u7684\u66F2\u7EBF\u5B8C\u5168\u538B\u5728\u75C5\u4EBA\u8EAB\u4E0A\uFF0C\u7537\u4EBA\u5F80\u5F80\u5728\u6211\u8EAB\u4E0B\u7ACB\u523B\u201C\u590D\u6D3B\u201D\u3002\u4F46\u6700\u723D\u7684\u5728\u540E\u9762\uFF1A\u4E0B\u73ED\u540E\u6211\u559C\u6B22\u7559\u5728\u7A7A\u8361\u8361\u7684\u6C99\u6EE9\u4E0A\uFF0C\u628A\u6E7F\u900F\u7684\u7EA2\u8272\u6CF3\u8863\u5168\u8131\u5149\uFF0C\u8D64\u88F8\u8EBA\u5728\u6E29\u70ED\u7684\u6C99\u5B50\u4E0A\u81EA\u6170\u597D\u51E0\u4E2A\u5C0F\u65F6\u3002\u624B\u6307\u5728\u9634\u8482\u4E0A\u6ED1\u52A8\uFF0C\u7136\u540E\u4ECE\u5305\u91CC\u638F\u51FA\u6211\u90A3\u6839\u53C8\u7C97\u53C8\u5927\u7684\u5047\u9633\u5177\uFF0C\u76F4\u63A5\u63D2\u8FDB\u6C99\u91CC\uFF0C\u8DE8\u5750\u4E0A\u53BB\u5F00\u59CB\u4E0A\u4E0B\u9A91\u4E58\u2014\u2014\u5148\u6162\u540E\u5FEB\uFF0C\u76F4\u5230\u9AD8\u6F6E\u6765\u5F97\u592A\u731B\uFF0C\u6211\u5BF9\u7740\u7A7A\u65E0\u4E00\u4EBA\u7684\u6D77\u6EE9\u5C16\u53EB\u3002 
      \u6C99\u6EE9\u6027\u7231\u662F\u6211\u7684\u6700\u7231\uFF1A\u5149\u6E9C\u6E9C\u7684\u8EAB\u4F53\u8EBA\u5728\u6C99\u5B50\u4E0A\uFF0C\u54B8\u6E7F\u7684\u6D77\u98CE\uFF0C\u6D77\u6D6A\u58F0\u4E2D\u88AB\u72E0\u72E0\u5730\u63D2\u5230\u6700\u6DF1\u5904\u2014\u2014\u5B8C\u4E8B\u540E\u6211\u518D\u8131\u5149\uFF0C\u7EE7\u7EED\u9A91\u6211\u7684\u5047\u9E21\u5DF4\u518D\u9AD8\u6F6E\u4E00\u6B21\u3002\u628A\u4ED6\u62D6\u4E0A\u5CB8\u540E\uFF0C\u6211\u628A\u4ED6\u625B\u5230\u9690\u853D\u5904\u201C\u6062\u590D\u201D\uFF0C\u8131\u6389\u7EA2\u8272\u6CF3\u8863\uFF0C\u628A\u5976\u5B50\u3001\u5C41\u80A1\u8FD8\u6709\u6211\u5728\u6C99\u6EE9\u4E0A\u9A91\u5047\u9633\u5177\u7684\u6837\u5B50\u5168\u7ED9\u4ED6\u770B\u3002\u4ED6\u77AC\u95F4\u5C31\u201C\u6D3B\u201D\u4E86\uFF0C\u73B0\u5728\u6BCF\u4E2A\u5468\u672B\u90FD\u5728\u6211\u8D1F\u8D23\u7684\u533A\u57DF\u201C\u6EBA\u6C34\u201D\uFF0C\u597D\u8BA9\u6211\u518D\u6551\u4ED6\u4E00\u6B21\u2014\u2014\u7136\u540E\u6211\u4EEC\u4FE9\u4E00\u76F4\u88F8\u7740\u505A\u5230\u5929\u4EAE\u3002"
    fr: "Je m\u2019appelle Skylar, je suis ma\xEEtre-nageuse sur la plage principale
      de la ville et c\u2019est moi qui ai vu \xAB$$$\xBB commencer \xE0 couler derri\xE8re
      les bou\xE9es. J\u2019ai plong\xE9 dans mon maillot rouge ultra-moulant qui
      retient \xE0 peine mon \xE9norme poitrine lourde et mon cul rond et juteux,
