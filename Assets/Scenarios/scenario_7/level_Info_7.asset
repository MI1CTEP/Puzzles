    zh: "\u6211\u53EBShanti\uFF0C\u662F\u56FE\u4E66\u9986\u5458\uFF0C\u4E00\u5934\u957F\u957F\u7684\u4EAE\u7EA2\u5934\u53D1\uFF0C\u8EAB\u6750\u8BF1\u4EBA\uFF0C\u8FDE\u6700\u4E25\u8C28\u7684\u8863\u670D\u90FD\u906E\u4E0D\u4F4F\uFF1A\u767D\u886C\u886B\u7D27\u7D27\u5305\u88F9\u7740\u80F8\u90E8\uFF0C\u9152\u7EA2\u8272\u77ED\u88D9\u53EA\u5230\u5927\u817F\u4E00\u534A\u3002\u4E0B\u9762\u662F\u6211\u6700\u7231\u7684\u7EA2\u8272\u5BBD\u857E\u4E1D\u540A\u5E26\u889C\u548C\u540A\u889C\u5E26\uFF0C\u5F53\u7136\u6CA1\u6709\u5185\u88E4\u3002\u9F3B\u6881\u4E0A\u67B6\u7740\u7CBE\u81F4\u7684\u7EC6\u6846\u773C\u955C\uFF0C\u8BA9\u6211\u770B\u8D77\u6765\u50CF\u4E2A\u4E25\u5389\u5374\u8D85\u7EA7\u6DEB\u8361\u7684\u8001\u5E08\u3002\u90A3\u5929
      \xAB$$$\xBB \u7B2C\u4E00\u6B21\u6765\u6211\u4EEC\u56FE\u4E66\u9986\u2014\u2014\u9AD8\u5927\u3001\u886C\u886B\u6574\u9F50\uFF0C\u4F4E\u58F0\u8BE2\u95EE\u4E00\u672C\u4ED6\u627E\u4E86\u5F88\u4E45\u7684\u73CD\u7A00\u5C0F\u8BF4\u3002\u6211\u77AC\u95F4\u4E0B\u9762\u4E00\u7D27\uFF1A\u4ED6\u8BF4\u8BDD\u8F7B\u67D4\u3001\u51C6\u786E\uFF0C\u8FDE\u4F5C\u8005\u548C\u51FA\u7248\u5E74\u4EFD\u90FD\u8BF4\u5F97\u5934\u5934\u662F\u9053\u2014\u2014\u771F\u6B63\u7684\u4E66\u866B\u7537\u4EBA\uFF0C\u8FD9\u79CD\u4EBA\u4E00\u51FA\u73B0\u6211\u5C31\u6E7F\u5F97\u4E0D\u884C\u3002\u6211\u5FAE\u7B11\u7740\u63A8\u4E86\u63A8\u773C\u955C\uFF0C\u5E26\u4ED6\u53BB\u6700\u91CC\u9762\u7684\u4E66\u5E93\uFF0C\u6545\u610F\u8D70\u5728\u524D\u5934\uFF0C\u8BA9\u4ED6\u770B\u5230\u77ED\u88D9\u6BCF\u8FC8\u4E00\u6B65\u5C31\u5411\u4E0A\u6380\uFF0C\u9732\u51FA\u7EA2\u8272\u540A\u5E26\u889C\u7684\u857E\u4E1D\u8FB9\u3002\u6211\u6700\u7231\u7231\u8BFB\u4E66\u7684\u7537\u4EBA\uFF0C\u56E0\u4E3A\u53EA\u6709\u4ED6\u4EEC\u771F\u6B63\u61C2\u5F97\u201C\u9605\u8BFB\u201D\u5973\u4EBA\u7684\u8EAB\u4F53\u3002\u56FE\u4E66\u9986\u6CA1\u4EBA\u65F6\u6211\u5C31\u9501\u4E0A\u95E8\uFF0C\u5750\u8FDB\u6DF1\u76AE\u6C99\u53D1\uFF0C\u628A\u77ED\u88D9\u64A9\u5230\u8170\u4E0A\uFF0C\u5728\u7EA2\u8272\u4E1D\u889C\u91CC\u5F20\u5F00\u817F\u81EA\u6170\u51E0\u4E2A\u5C0F\u65F6\uFF1A\u624B\u6307\u6162\u6162\u7ED5\u7740\u9634\u8482\u6253\u5708\uFF0C\u518D\u63D2\u8FDB\u4E24\u6839\u6DF1\u4E00\u70B9\uFF0C\u7136\u540E\u63B0\u5F00\u5C41\u80A1\u628A\u7B2C\u4E09\u6839\u585E\u8FDB\u7D27\u81F4\u7684\u5C0F\u83CA\u82B1\uFF0C\u5E7B\u60F3\u6709\u4E2A\u806A\u660E\u5F3A\u58EE\u7684\u7537\u4EBA\u8EB2\u5728\u4E66\u67B6\u540E\u5077\u770B\u3002\u6700\u723D\u7684\u662F\u89D2\u843D\u90A3\u9762\u7279\u522B\u7684\u5899\u2014\u2014\u9F50\u8170\u9AD8\u6709\u4E2A\u5C0F\u6D1E\u3002\u6211\u8DEA\u5728\u53E6\u4E00\u8FB9\uFF0C\u7B49\u7740\u4E0B\u4E00\u4E2A\u4E66\u866B\u6765\u201C\u627E\u4E66\u201D\uFF0C\u62C9\u5F00\u4ED6\u88E4\u94FE\u628A\u9E21\u5DF4\u542B\u8FDB\u5634\u91CC\u