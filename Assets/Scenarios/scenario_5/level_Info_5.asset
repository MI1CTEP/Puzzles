  nameLevel: Imani
  languages:
    ru: "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 Imani, \u044F \u043F\u0430\u0442\u0440\u0443\u043B\u044C\u043D\u044B\u0439
      \u043E\u0444\u0438\u0446\u0435\u0440, \u0437\u0430\u0433\u043E\u0440\u0435\u043B\u0430\u044F,
      \u0441 \u0430\u043F\u043F\u0435\u0442\u0438\u0442\u043D\u044B\u043C\u0438 \u0444\u043E\u0440\u043C\u0430\u043C\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0430\u0436\u0435 \u0441\u0442\u0440\u043E\u0433\u0430\u044F
      \u043F\u043E\u043B\u0438\u0446\u0435\u0439\u0441\u043A\u0430\u044F \u0444\u043E\u0440\u043C\u0430
      \u043D\u0435 \u0432 \u0441\u0438\u043B\u0430\u0445 \u0441\u043A\u0440\u044B\u0442\u044C:
      \u0440\u0443\u0431\u0430\u0448\u043A\u0430 \u043D\u0430\u0442\u044F\u043D\u0443\u0442\u0430
      \u043D\u0430 \u043F\u043E\u043B\u043D\u043E\u0439 \u0433\u0440\u0443\u0434\u0438,
      \u0444\u043E\u0440\u043C\u0435\u043D\u043D\u0430\u044F \u044E\u0431\u043A\u0430
      \u043E\u0431\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442 \u043A\u0440\u0443\u0433\u043B\u0443\u044E
      \u043F\u043E\u043F\u043A\u0443, \u0430 \u043F\u043E\u0434 \u043D\u0435\u0439
      \u2014 \u0431\u0435\u043B\u044B\u0435 \u0447\u0443\u043B\u043A\u0438 \u0441
      \u0448\u0438\u0440\u043E\u043A\u043E\u0439 \u0440\u0435\u0437\u0438\u043D\u043A\u043E\u0439
      \u0438 \u043F\u043E\u044F\u0441, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
      \u044F \u0441\u0447\u0438\u0442\u0430\u044E, \u0447\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F
      \u043F\u043E\u043B\u0438\u0446\u0435\u0439\u0441\u043A\u0430\u044F \u0434\u043E\u043B\u0436\u043D\u0430
      \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u0442\u044C \u0441\u0435\u043A\u0441\u0443\u0430\u043B\u044C\u043D\u043E
      \u0438 \u0432\u043B\u0430\u0441\u0442\u043D\u043E \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E.
      \u0412 \u0442\u043E\u0442 \u0432\u0435\u0447\u0435\u0440 \u044F \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043B\u0430
      \xAB$$$\xBB \u0437\u0430 \u043C\u0435\u043B\u043A\u043E\u0435 \u043D\u0430\u0440\u0443\u0448\u0435\u043D\u0438\u0435:
      \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u0434\u043E\u043B\u0433\u043E \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430
      \u043C\u0435\u043D\u044F, \u043F\u043E\u043A\u0430 \u044F \u0448\u043B\u0430
      \u043F\u043E \u0443\u043B\u0438\u0446\u0435, \u0438 \u044F \u0440\u0435\u0448\u0438\u043B\u0430,
      \u0447\u0442\u043E \u044D\u0442\u043E \u043F\u043E\u0432\u043E\u0434 \u0437\u0430\u0431\u0440\u0430\u0442\u044C
      \u0435\u0433\u043E \u0432 \u0443\u0447\u0430\u0441\u0442\u043E\u043A \xAB\u0434\u043B\u044F
      \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u044F\xBB. \u041F\u0440\u0438\u0432\u0435\u043B\u0430
      \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0443 \u0434\u043B\u044F \u0434\u043E\u043F\u0440\u043E\u0441\u043E\u0432,
      \u043F\u043E\u0441\u0430\u0434\u0438\u043B\u0430 \u0437\u0430 \u0441\u0442\u0435\u043A\u043B\u043E,
      \u043F\u0440\u0438\u0441\u0442\u0435\u0433\u043D\u0443\u043B\u0430 \u043D\u0430\u0440\u0443\u0447\u043D\u0438\u043A\u0438
      \u043A \u0441\u0442\u043E\u043B\u0443 \u0438 \u043D\u0430\u0447\u0430\u043B\u0430
      \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0442\u044C
      \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B, \u0437\u043D\u0430\u044F,
      \u0447\u0442\u043E \u043E\u043D \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
      \u043E\u0442\u0432\u0435\u0441\u0442\u0438 \u043E\u0442 \u043C\u0435\u043D\u044F
      \u0433\u043B\u0430\u0437. \u042F \u043E\u0431\u043E\u0436\u0430\u044E, \u043A\u043E\u0433\u0434\u0430
      \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u044B\u0435 \u043D\u0435\u0440\u0432\u043D\u0438\u0447\u0430\u044E\u0442,
      \u0438 \u043B\u0443\u0447\u0448\u0435\u0435 \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
      \u2014 \u044D\u0442\u043E \u044F \u0441\u0430\u043C\u0430. \u041F\u043E\u043A\u0430
      \u043F\u0438\u0448\u0443, \xAB\u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\xBB
      \u0440\u0430\u0441\u0441\u0442\u0451\u0433\u0438\u0432\u0430\u044E \u0432\u0435\u0440\u0445\u043D\u0438\u0435
      \u043F\u0443\u0433\u043E\u0432\u0438\u0446\u044B \u0440\u0443\u0431\u0430\u0448\u043A\u0438,
      \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0443\u0432\u0438\u0434\u0435\u043B
      \u043C\u043E\u044E \u0437\u0430\u0433\u043E\u0440\u0435\u043B\u0443\u044E \u0433\u0440\u0443\u0434\u044C,
      \u043F\u043E\u0447\u0442\u0438 \u0432\u044B\u0432\u0430\u043B\u0438\u0432\u0430\u044E\u0449\u0443\u044E\u0441\u044F
      \u0438\u0437 \u043A\u0440\u0443\u0436\u0435\u0432\u043D\u043E\u0433\u043E \u043B\u0438\u0444\u0447\u0438\u043A\u0430.
      \u041F\u043E\u0442\u043E\u043C \u0432\u0441\u0442\u0430\u044E, \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u044E\u0441\u044C
      \u0441\u043F\u0438\u043D\u043E\u0439, \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u044E
      \u044E\u0431\u043A\u0443 \u0438 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E
      \u0447\u0435\u0440\u0435\u0437 \u0441\u0442\u0435\u043A\u043B\u043E \u0441\u0432\u043E\u044E
      \u0441\u043E\u0447\u043D\u0443\u044E \u043F\u043E\u043F\u043A\u0443 \u0432
      \u0442\u043E\u043D\u043A\u0438\u0445 \u0431\u0435\u043B\u044B\u0445 \u0441\u0442\u0440\u0438\u043D\u0433\u0430\u0445,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0443\u0436\u0435 \u043F\u0440\u043E\u043C\u043E\u043A\u043B\u0438.
      \u0410 \u0437\u0430\u0442\u0435\u043C \u0441\u0430\u0436\u0443\u0441\u044C
      \u043D\u0430 \u0441\u0442\u043E\u043B \u043F\u0440\u044F\u043C\u043E \u043D\u0430\u043F\u0440\u043E\u0442\u0438\u0432
      \u043D\u0435\u0433\u043E, \u0440\u0430\u0437\u0434\u0432\u0438\u0433\u0430\u044E
      \u043D\u043E\u0433\u0438 \u0432 \u0431\u0435\u043B\u044B\u0445 \u0447\u0443\u043B\u043A\u0430\u0445
      \u0438 \u043E\u0442\u043E\u0434\u0432\u0438\u0433\u0430\u044E \u0442\u0440\u0443\u0441\u0438\u043A\u0438
      \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u2014 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E
      \u0433\u043B\u0430\u0434\u043A\u0443\u044E \u043A\u0438\u0441\u043A\u0443,
      \u0440\u0430\u0437\u0434\u0432\u0438\u0433\u0430\u044E \u0433\u0443\u0431\u043A\u0438
      \u043F\u0430\u043B\u044C\u0447\u0438\u043A\u0430\u043C\u0438, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043D \u0443\u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u044F
      \u0442\u0435\u043A\u0443 \u043E\u0442 \u043E\u0434\u043D\u043E\u0439 \u043C\u044B\u0441\u043B\u0438
      \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u0435\u0439\u0447\u0430\u0441
      \u0441\u0434\u0435\u043B\u0430\u044E. \u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
      \u0433\u043E\u0442\u043E\u0432, \u044F \u0437\u0430\u0445\u043E\u0436\u0443
      \u043A \u043D\u0435\u043C\u0443 \u0432 \u043A\u0430\u043C\u0435\u0440\u0443,
      \u043E\u043F\u0443\u0441\u043A\u0430\u044E\u0441\u044C \u043D\u0430 \u043A\u043E\u043B\u0435\u043D\u0438
      \u043F\u0440\u044F\u043C\u043E \u0432 \u0444\u043E\u0440\u043C\u0435, \u0440\u0430\u0441\u0441\u0442\u0451\u0433\u0438\u0432\u0430\u044E
      \u0435\u0433\u043E \u0431\u0440\u044E\u043A\u0438 \u0438 \u0431\u0435\u0440\u0443
      \u0447\u043B\u0435\u043D \u0432 \u0440\u043E\u0442 \u2014 \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E,
      \u0433\u043B\u0443\u0431\u043E\u043A\u043E, \u0434\u043E \u0441\u0430\u043C\u043E\u0433\u043E
      \u0433\u043E\u0440\u043B\u0430, \u0433\u043B\u044F\u0434\u044F \u0435\u043C\u0443
      \u0432 \u0433\u043B\u0430\u0437\u0430. \u042F \u0434\u0435\u043B\u0430\u044E
      \u043B\u0443\u0447\u0448\u0438\u0439 \u043C\u0438\u043D\u0435\u0442 \u0432
      \u0443\u0447\u0430\u0441\u0442\u043A\u0435: \u0441\u043E\u0441\u0443 \u0436\u0430\u0434\u043D\u043E,
      \u043E\u0431\u043B\u0438\u0437\u044B\u0432\u0430\u044E \u043A\u0430\u0436\u0434\u0443\u044E
      \u0432\u0435\u043D\u0443, \u0437\u0430\u0433\u043B\u0430\u0442\u044B\u0432\u0430\u044E
      \u0446\u0435\u043B\u0438\u043A\u043E\u043C, \u043F\u043E\u043A\u0430 \u043E\u043D
      \u043D\u0435 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u0434\u0440\u043E\u0436\u0430\u0442\u044C
      \u0438 \u043A\u043E\u043D\u0447\u0430\u0442\u044C \u043C\u043D\u0435 \u043F\u0440\u044F\u043C\u043E
      \u0432 \u0440\u043E\u0442\u0438\u043A. \u042F \u0433\u043B\u043E\u0442\u0430\u044E
      \u0432\u0441\u0451, \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439
      \u043A\u0430\u043F\u0435\u043B\u044C\u043A\u0438, \u043E\u0431\u043B\u0438\u0437\u044B\u0432\u0430\u044E
      \u0433\u0443\u0431\u044B \u0438 \u0448\u0435\u043F\u0447\u0443: \xAB\u041F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
      \u0437\u0430\u043A\u0440\u044B\u0442, \u0442\u044B \u0441\u0432\u043E\u0431\u043E\u0434\u0435\u043D\u2026
      \u043D\u043E \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
      \u0440\u0430\u0437 \u043D\u0430\u0440\u0443\u0448\u0430\u0439 \u043F\u043E\u0441\u0435\u0440\u044C\u0451\u0437\u043D\u0435\u0435,
      \u0447\u0442\u043E\u0431\u044B \u044F \u0441\u043C\u043E\u0433\u043B\u0430
      \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0442\u0435\u0431\u044F \u043D\u0430
      \u043D\u043E\u0447\u044C\xBB. \u0414\u043B\u044F \u043C\u0435\u043D\u044F \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u0430\u044F
      \u0441\u043C\u0435\u043D\u0430 \u2014 \u044D\u0442\u043E \u043A\u043E\u0433\u0434\u0430
      \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u044B\u0439 \u0443\u0445\u043E\u0434\u0438\u0442
      \u0438\u0437 \u0443\u0447\u0430\u0441\u0442\u043A\u0430 \u0440\u0430\u0441\u0441\u043B\u0430\u0431\u043B\u0435\u043D\u043D\u044B\u043C,
      \u0441 \u043F\u0443\u0441\u0442\u044B\u043C\u0438 \u044F\u0439\u0446\u0430\u043C\u0438
      \u0438 \u043C\u043E\u0438\u043C \u0432\u043A\u0443\u0441\u043E\u043C \u043D\u0430
      \u0433\u0443\u0431\u0430\u0445, \u0430 \u044F \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044E\u0441\u044C
      \u0437\u0430 \u0441\u0442\u0435\u043A\u043B\u043E, \u0441\u043D\u043E\u0432\u0430
      \u0440\u0430\u0437\u0434\u0432\u0438\u0433\u0430\u044E \u043D\u043E\u0433\u0438
      \u0432 \u0431\u0435\u043B\u044B\u0445 \u0447\u0443\u043B\u043A\u0430\u0445
      \u0438 \u0436\u0434\u0443 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0433\u043E
      \xAB\u043D\u0430\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044F\xBB."
    en: "My name is Imani, I\u2019m a patrol officer \u2014 tanned, with curves that
      even the strict police uniform can\u2019t hide: the shirt is stretched tight
      over my full breasts, the regulation skirt hugs my round ass, and underneath
      \u2014 white stockings with wide lace tops and a garter belt, because I believe
      a real policewoman should look both sexy and commanding at the same time. That
      evening I detained \xAB$$$\xBB for a minor offence: he just stared at me too
      long while I was walking down the street, so I decided it was a reason to take
      him to the station \u201Cfor processing\u201D. I brought him into the interrogation
      room, sat him behind the glass, cuffed him to the table and started slowly
      filling out the report, knowing he couldn\u2019t take his eyes off me. I love
      it when detainees get nervous, and the best sedative is me. While writing,
      I \u201Caccidentally\u201D undo the top buttons of my shirt so he can see my
      tanned cleavage almost spilling out of the lace bra. Then I stand up, turn
      my back to him, lift my skirt and show him through the glass my juicy ass in
      thin white thong panties that are already soaked. Then I sit on the table right
      in front of him, spread my legs in white stockings and push the panties aside
      \u2014 showing him my smooth pussy, spreading the lips with my fingers so he
      can see how wet I am just thinking about what I\u2019m going to do next. When
      the report is ready, I walk into his cell, drop to my knees still in uniform,
      unzip his trousers and take his cock in my mouth \u2014 slow, deep, all the
      way down my throat, looking him straight in the eyes. I give the best blowjob
      in the precinct: sucking hungrily, licking every vein, swallowing him whole
      until he starts shaking and cums straight into my mouth. I swallow everything,
      down to the last drop, lick my lips and whisper: \u201CCase closed, you\u2019re
      free\u2026 but next time break the law a little more seriously so I can keep
      you overnight.\u201D For me the perfect shift is when the detainee leaves the
      station relaxed, balls empty and my taste on his lips, and I go back behind
      the glass, spread my legs in white stockings again and wait for the next \u201Coffender\u201D."
    de: "Ich hei\xDFe Imani, ich bin Streifenpolizistin \u2013 gebr\xE4unt, mit Kurven,
      die selbst die strenge Polizeiuniform nicht verstecken kann: das Hemd spannt
      \xFCber meinen vollen Br\xFCsten, der Dienstrock umschlie\xDFt meinen runden
      Arsch, und darunter \u2013 wei\xDFe Str\xFCmpfe mit breitem Spitzenrand und
      Strapsg\xFCrtel, denn ich finde, eine echte Polizistin muss gleichzeitig sexy
      und autorit\xE4r aussehen. An diesem Abend habe ich \xAB$$$\xBB wegen einer
      Kleinigkeit festgenommen: er hat mich einfach zu lange angestarrt, w\xE4hrend
      ich die Stra\xDFe entlangging, also beschloss ich, das sei Grund genug, ihn
      \u201Ezur Bearbeitung\u201C mit aufs Revier zu nehmen. Ich brachte ihn in den
      Verh\xF6rraum, setzte ihn hinter die Glasscheibe, fesselte ihn mit Handschellen
      an den Tisch und begann langsam das Protokoll auszuf\xFCllen, wohl wissend,
      dass er den Blick nicht von mir abwenden konnte. Ich liebe es, wenn Festgenommene
      nerv\xF6s werden, und das beste Beruhigungsmittel bin ich selbst. W\xE4hrend
      ich schreibe, \u201Eversehentlich\u201C die oberen Kn\xF6pfe meiner Bluse \xF6ffne,
      damit er mein gebr\xE4untes Dekollet\xE9 sieht, das fast aus dem Spitzen-BH
      quillt. Dann stehe ich auf, drehe mich um, hebe den Rock und zeige ihm durch
      die Scheibe meinen saftigen Arsch in einem d\xFCnnen wei\xDFen String, der
      schon ganz nass ist. Dann setze ich mich direkt vor ihn auf den Tisch, spreize
      die Beine in wei\xDFen Str\xFCmpfen und schiebe den String zur Seite \u2013
      zeige ihm meine glatte Muschi, spreize die Schamlippen mit den Fingern, damit
      er sieht, wie ich nur vom Gedanken an das, was ich gleich tun werde, schon
      tropfe. Als das Protokoll fertig ist, gehe ich zu ihm in die Zelle, knie mich
      in Uniform hin, \xF6ffne seine Hose und nehme seinen Schwanz in den Mund \u2013
      langsam, tief, bis zum Anschlag in meiner Kehle, und schaue ihm dabei in die
      Augen. Ich mache den besten Blowjob im ganzen Revier: sauge gierig, lecke jede
      Ader, verschlinge ihn komplett, bis er zittert und mir direkt in den Mund spritzt.
