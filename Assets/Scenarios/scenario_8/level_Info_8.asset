  nameLevel: Nia
  languages:
    ru: "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 Nia, \u044F \u0430\u043C\u0430\u0437\u043E\u043D\u043A\u0430
      \u0441 \u042F\u043C\u0430\u0439\u043A\u0438, \u0441\u043C\u0443\u0433\u043B\u0430\u044F,
      \u0441 \u0442\u0443\u0433\u043E\u0439 \u0441\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u043E\u0439
      \u0444\u0438\u0433\u0443\u0440\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
      \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
      \u043C\u043E\u0451 \u043B\u0451\u0433\u043A\u043E\u0435 \xAB\u0431\u0435\u043B\u044C\u0451\xBB
      \u0438\u0437 \u0442\u043E\u043D\u043A\u0438\u0445 \u043A\u043E\u0436\u0430\u043D\u044B\u0445
      \u0440\u0435\u043C\u0435\u0448\u043A\u043E\u0432 \u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
      \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
      \u0442\u043A\u0430\u043D\u0438: \u043E\u0434\u0438\u043D \u0435\u0434\u0432\u0430
      \u043F\u0440\u0438\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0443\u043F\u0440\u0443\u0433\u0438\u0435
      \u0433\u0440\u0443\u0434\u0438, \u0434\u0440\u0443\u0433\u043E\u0439 \u2014
      \u043C\u0435\u0436\u0434\u0443 \u043D\u043E\u0433, \u043D\u043E \u0441\u0442\u043E\u0438\u0442
      \u043C\u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0433\u043D\u0443\u0442\u044C\u0441\u044F,
      \u0438 \u0432\u0441\u0451 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F.
      \u0412 \u0434\u0436\u0443\u043D\u0433\u043B\u044F\u0445 \u043E\u0434\u0435\u0436\u0434\u0430
      \u2014 \u043B\u0438\u0448\u043D\u0435\u0435, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E \u044F \u0445\u043E\u0436\u0443
      \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0433\u043E\u043B\u0430\u044F,
      \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044F, \u043A\u0430\u043A \u0441\u043E\u043B\u043D\u0446\u0435
      \u0438 \u0432\u0435\u0442\u0435\u0440 \u043B\u0430\u0441\u043A\u0430\u044E\u0442
      \u043C\u043E\u044E \u043A\u043E\u0436\u0443. \u0412 \u0442\u043E\u0442 \u0434\u0435\u043D\u044C
      \u044F \u0443\u0441\u043B\u044B\u0448\u0430\u043B\u0430 \u0433\u0440\u043E\u0445\u043E\u0442
      \u0438 \u043F\u043E\u0431\u0435\u0436\u0430\u043B\u0430 \u043D\u0430 \u0437\u0432\u0443\u043A:
      \u043B\u0451\u0433\u043A\u0438\u0439 \u0441\u0430\u043C\u043E\u043B\u0451\u0442
      \u0440\u0443\u0445\u043D\u0443\u043B \u0432 \u0437\u0430\u0440\u043E\u0441\u043B\u0438,
      \u0430 \u0438\u0437 \u043E\u0431\u043B\u043E\u043C\u043A\u043E\u0432 \u0432\u044B\u0431\u0440\u0430\u043B\u0441\u044F
      \u043E\u043D \u2014  \xAB$$$\xBB . \u0412\u044B\u0441\u043E\u043A\u0438\u0439,
      \u0432\u0435\u0441\u044C \u0432 \u043F\u044B\u043B\u0438 \u0438 \u0446\u0430\u0440\u0430\u043F\u0438\u043D\u0430\u0445,
      \u043D\u043E \u0436\u0438\u0432\u043E\u0439 \u0438 \u0442\u0430\u043A\u043E\u0439\u2026
      \u0436\u0435\u043B\u0430\u043D\u043D\u044B\u0439. \u0414\u0430\u0432\u043D\u043E
      \u0432 \u043D\u0430\u0448\u0438\u0445 \u0434\u0436\u0443\u043D\u0433\u043B\u044F\u0445
      \u043D\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u043B\u043E\u0441\u044C \u043C\u0443\u0436\u0447\u0438\u043D,
      \u0430 \u043C\u043D\u0435 \u0442\u0430\u043A \u043E\u0434\u0438\u043D\u043E\u043A\u043E
      \u043F\u043E \u043D\u043E\u0447\u0430\u043C \u0443 \u043A\u043E\u0441\u0442\u0440\u0430.
      \u042F \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u043D\u044F\u043B\u0430:
      \u044D\u0442\u043E\u0433\u043E \u044F \u043D\u0435 \u043E\u0442\u043F\u0443\u0449\u0443
      \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0430\u043A. \u042F \u043F\u043E\u0434\u0432\u0435\u043B\u0430
      \u0435\u0433\u043E \u043A \u0432\u043E\u0434\u043E\u043F\u0430\u0434\u0443
      \u2014 \u043C\u043E\u0435\u043C\u0443 \u043B\u044E\u0431\u0438\u043C\u043E\u043C\u0443
      \u043C\u0435\u0441\u0442\u0443, \u0433\u0434\u0435 \u0432\u043E\u0434\u0430
      \u043F\u0430\u0434\u0430\u0435\u0442 \u0441 \u0432\u044B\u0441\u043E\u0442\u044B,
      \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u044F\u0441\u044C \u043E \u043A\u0430\u043C\u043D\u0438
      \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u0430\u043C\u0438 \u0431\u0440\u044B\u0437\u0433.
      \u0422\u0430\u043C \u044F \u0441\u0431\u0440\u043E\u0441\u0438\u043B\u0430
      \u0441\u0432\u043E\u0438 \u0440\u0435\u043C\u0435\u0448\u043A\u0438, \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
      \u0433\u043E\u043B\u043E\u0439 \u0438 \u0432\u043E\u0448\u043B\u0430 \u0432
      \u0432\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0443\u0432\u0438\u0434\u0435\u043B
      \u0432\u0441\u0451: \u043C\u043E\u044E \u0441\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u0443\u044E
      \u043F\u043E\u043F\u043A\u0443, \u043A\u043E\u0433\u0434\u0430 \u044F \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u044E\u0441\u044C,
      \u0443\u043F\u0440\u0443\u0433\u0438\u0435 \u0433\u0440\u0443\u0434\u0438,
      \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u044E
      \u0440\u0443\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0436\u0430\u0442\u044C
      \u043C\u043E\u043A\u0440\u044B\u0435 \u0432\u043E\u043B\u043E\u0441\u044B,
      \u0438 \u0433\u043B\u0430\u0434\u043A\u0443\u044E \u043A\u0438\u0441\u043A\u0443,
      \u043A\u043E\u0433\u0434\u0430 \u0440\u0430\u0437\u0434\u0432\u0438\u0433\u0430\u044E
      \u043D\u043E\u0433\u0438, \u0441\u0442\u043E\u044F \u043F\u043E\u0434 \u0441\u0442\u0440\u0443\u044F\u043C\u0438.
      \u042F \u0434\u0438\u043A\u0430\u044F, \u0438 \u043C\u043D\u0435 \u043D\u0435
      \u043D\u0443\u0436\u043D\u044B \u0441\u043B\u043E\u0432\u0430: \u0435\u0441\u043B\u0438
      \u043C\u0443\u0436\u0447\u0438\u043D\u0430 \u0437\u0430\u0431\u0440\u0435\u043B
      \u0432 \u043C\u043E\u0438 \u0434\u0436\u0443\u043D\u0433\u043B\u0438 \u2014
      \u043E\u043D \u043C\u043E\u0439. \u042F \u043B\u044E\u0431\u043B\u044E \u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u043A\u043E\u043B\u0435\u043D\u0438 \u043F\u0440\u044F\u043C\u043E
      \u043D\u0430 \u043C\u043E\u043A\u0440\u044B\u0445 \u043A\u0430\u043C\u043D\u044F\u0445
      \u0443 \u0432\u043E\u0434\u043E\u043F\u0430\u0434\u0430, \u0432\u0437\u044F\u0442\u044C
      \u0435\u0433\u043E \u0447\u043B\u0435\u043D \u0432 \u0440\u043E\u0442 \u0438
      \u0441\u043E\u0441\u0430\u0442\u044C \u0436\u0430\u0434\u043D\u043E, \u0433\u043B\u0443\u0431\u043E\u043A\u043E,
      \u043F\u043E\u043A\u0430 \u0432\u043E\u0434\u0430 \u0441\u0442\u0435\u043A\u0430\u0435\u0442
      \u043F\u043E \u043C\u043E\u0435\u0439 \u0441\u043F\u0438\u043D\u0435 \u0438
      \u043E\u043D \u043D\u0435 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442
      \u0441\u0442\u043E\u043D\u0430\u0442\u044C \u0433\u0440\u043E\u043C\u0447\u0435
      \u0448\u0443\u043C\u0430 \u0432\u043E\u0434\u043E\u043F\u0430\u0434\u0430.
      \u0410 \u043F\u043E\u0442\u043E\u043C \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u044E\u0441\u044C,
      \u0443\u043F\u0438\u0440\u0430\u044E\u0441\u044C \u0440\u0443\u043A\u0430\u043C\u0438
      \u0432 \u043A\u0430\u043C\u0435\u043D\u044C, \u0432\u044B\u0433\u0438\u0431\u0430\u044E
      \u0441\u043F\u0438\u043D\u0443 \u0438 \u043F\u0440\u043E\u0448\u0443 \u0432\u0437\u044F\u0442\u044C
      \u043C\u0435\u043D\u044F \u0432 \u043F\u043E\u043F\u043A\u0443 \u2014 \u0436\u0451\u0441\u0442\u043A\u043E,
      \u0434\u043E \u043A\u043E\u043D\u0446\u0430, \u0447\u0442\u043E\u0431\u044B
      \u044F \u043A\u0440\u0438\u0447\u0430\u043B\u0430 \u043E\u0442 \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F
      \u0432 \u043F\u0443\u0441\u0442\u044B\u0435 \u0434\u0436\u0443\u043D\u0433\u043B\u0438.
      \u0410\u043D\u0430\u043B \u0441\u0440\u0435\u0434\u0438 \u043B\u0438\u0430\u043D
      \u0438 \u0432\u043E\u0434\u043E\u043F\u0430\u0434\u043E\u0432 \u2014 \u044D\u0442\u043E
      \u0442\u043E, \u0440\u0430\u0434\u0438 \u0447\u0435\u0433\u043E \u044F \u0436\u0438\u0432\u0443.
      \u042F \u043B\u044E\u0431\u043B\u044E \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C,
      \u043A\u0430\u043A \u043E\u043D \u0440\u0430\u0441\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442
      \u043C\u043E\u044E \u0442\u0443\u0433\u0443\u044E \u0441\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u0443\u044E
      \u043F\u043E\u043F\u043A\u0443, \u043A\u0430\u043A \u0432\u0445\u043E\u0434\u0438\u0442
      \u0432\u0441\u0451 \u0433\u043B\u0443\u0431\u0436\u0435, \u043F\u043E\u043A\u0430
      \u044F \u043D\u0435 \u043D\u0430\u0447\u0438\u043D\u0430\u044E \u0434\u0440\u043E\u0436\u0430\u0442\u044C
      \u0438 \u043A\u043E\u043D\u0447\u0430\u0442\u044C, \u0441\u0436\u0438\u043C\u0430\u044F
      \u0435\u0433\u043E \u0432\u043D\u0443\u0442\u0440\u0438 \u0441\u0435\u0431\u044F.
      \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E \u044F \u0441\u043D\u043E\u0432\u0430
      \u043D\u044B\u0440\u044F\u044E \u0433\u043E\u043B\u0430\u044F \u0432 \u0432\u043E\u0434\u0443,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043C\u044B\u0442\u044C \u0432\u0441\u0451,
      \u043A\u0440\u043E\u043C\u0435 \u0435\u0433\u043E \u0437\u0430\u043F\u0430\u0445\u0430
      \u043D\u0430 \u043C\u043E\u0435\u0439 \u043A\u043E\u0436\u0435, \u0438 \u0432\u0435\u0434\u0443
      \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u0448\u0435 \u0432 \u0434\u0436\u0443\u043D\u0433\u043B\u0438
      \u2014 \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0442\u0435\u043F\u0435\u0440\u044C
      \u043E\u043D \u043C\u043E\u0439, \u0438 \u044F \u0431\u0443\u0434\u0443 \u0442\u0440\u0430\u0445\u0430\u0442\u044C\u0441\u044F
      \u0441 \u043D\u0438\u043C \u0443 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
      \u0432\u043E\u0434\u043E\u043F\u0430\u0434\u0430, \u043F\u043E\u043A\u0430
      \u043E\u043D \u043D\u0435 \u0437\u0430\u0431\u0443\u0434\u0435\u0442, \u0447\u0442\u043E
      \u0433\u0434\u0435-\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
      \u0434\u0440\u0443\u0433\u043E\u0439 \u043C\u0438\u0440. "
    en: "My name is Nia, I\u2019m a Jamaican Amazon \u2014 dark-skinned, with a tight
